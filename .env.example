# Copy this file to .env and fill in your own credentials.
# .env is git-ignored and must never be committed.

# NREL developer API key for NSRDB access.
# Request a free key at: https://developer.nrel.gov/signup/
NREL_API_KEY=your_nrel_api_key_here

# ---------------------------------------------------------------------------
# CAMS (Copernicus Atmosphere Monitoring Service) credentials are NOT stored
# here. The cdsapi client reads them from a separate credentials file:
#
#   Windows: %USERPROFILE%\.cdsapirc   (e.g. C:\Users\<you>\.cdsapirc)
#   Linux/macOS: ~/.cdsapirc
#
# That file should contain two lines:
#   url: https://ads.atmosphere.copernicus.eu/api
#   key: <your-ads-api-key>
#
# Register for free at: https://ads.atmosphere.copernicus.eu/
# ---------------------------------------------------------------------------
